# Copy to .env.local for local development.

# Optional — enables real Claude guidance (server-side only)
ANTHROPIC_API_KEY=

# Optional — Supabase data store
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Required for PATCH /api/evac-centers/:id/status
LGU_ADMIN_API_KEY=

# Production app URL for share links
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PAGASA bulletin ingestion cron (production on Vercel)
# Vercel Cron sends: Authorization: Bearer <CRON_SECRET>
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=

# Optional alias — same value as CRON_SECRET works for manual POST tests
INGEST_CRON_SECRET=
